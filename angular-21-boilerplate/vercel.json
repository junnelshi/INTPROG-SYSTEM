{
    "buildCommand": "npm install && npm run build",
    "outputDirectory": "dist/angular-15-example/browser",
    "routes": [
        {
            "src": "/(.*)\\.js",
            "headers": {
                "Content-Type": "application/javascript"
            },
            "dest": "/$1.js"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}